model Match {
  id        String      @id @default(cuid())
  homeUserId String
  awayUserId String?    // null para IA
  homeTeamId String
  awayTeamId String?    // null para IA
  
  homeUser User @relation("HomeUser", fields: [homeUserId], references: [id])
  awayUser User? @relation("AwayUser", fields: [awayUserId], references: [id])
  homeTeam Team @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team? @relation("AwayTeam", fields: [awayTeamId], references: [id])
  
  // Configurações da partida
  matchType   MatchType
  status      MatchStatus @default(SCHEDULED)
  
  // Resultado
  homeScore   Int @default(0) // Sets ganhos
  awayScore   Int @default(0) // Sets ganhos
  winnerId    String? // userId ou "AI"
  
  // Metadados
  scheduledAt DateTime?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime @default(now())
  
  // Relacionamentos
  sets        MatchSet[]
  events      MatchEvent[]
  rewards     MatchReward[]
  momentum    GameMomentum[]
  playerStats PlayerMatchStats[]
  
  // Sistema de narrativa
  narratorType NarratorType @default(STANDARD)
  crowdLevel   Int @default(50) // 0-100
  
  @@map("matches")
}

model MatchSet {
  id        String @id @default(cuid())
  matchId   String
  setNumber Int
  
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  homePoints Int @default(0)
  awayPoints Int @default(0)
  winnerId   String? // "home", "away", ou null se não finalizado
  
  startedAt  DateTime?
  finishedAt DateTime?
  
  @@unique([matchId, setNumber])
  @@map("match_sets")
}

model MatchReward {
  id      String @id @default(cuid())
  matchId String
  userId  String
  
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  // Recompensas
  coinsEarned Int @default(0)
  gemsEarned  Int @default(0)
  xpEarned    Int @default(0)
  
  // Tipo de recompensa
  rewardType RewardType
  reason     String // "victory", "participation", "achievement"
  
  claimed   Boolean @default(false)
  claimedAt DateTime?
  createdAt DateTime @default(now())
  
  @@map("match_rewards")
}

enum MatchType {
  FRIENDLY
  RANKED
  TOURNAMENT
  CAMPAIGN
  TRAINING
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum NarratorType {
  STANDARD
  ENTHUSIASTIC
  TECHNICAL
  DRAMATIC
}

enum RewardType {
  MATCH_VICTORY
  MATCH_PARTICIPATION
  ACHIEVEMENT_UNLOCK
  DAILY_BONUS
  SPECIAL_EVENT
}